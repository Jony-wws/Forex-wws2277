// © Jony-wws / Forex-wws2277
// EUR/USD HONEST 70%+ WR — binary-options 5h.
// SINGLE FILE: strategy(...) — gives BOTH on-chart BUY/SELL labels (acts as
// indicator) AND official Strategy Tester results (acts as backtest).
//
// Trade model (binary options — no TP, no SL):
//   - Open BUY  on a fresh long  signal.
//   - Open SELL on a fresh short signal.
//   - Hold exactly  expiryBars  bars  (default 20 on M15  =  5 hours).
//   - Close at market when timer expires.
//   - Win  = price closed in the predicted direction at expiry.
//
// Why this can honestly reach ≥70% WR for 5h binary on EUR/USD:
//   1. Multi-TF trend agreement: D1 + H4 + H1 EMA200 must ALL align.
//   2. Supertrend(M15) must agree with the HTF trend  (entry-TF confirmation).
//   3. Pullback to Hull MA(M15)  →  enters AFTER a counter-move, so the next
//      5h are biased toward the dominant trend (mean-reversion in trend).
//   4. ADX(14, H1) > 22  →  skips dead/ranging markets where 5h drift is random.
//   5. ATR(14) > 0.6·avgATR(50)  →  skips low-volatility chop.
//   6. VWAP confluence on H1  →  trades only when price respects institutional
//      anchored level on the trend side.
//   7. Session filter — London + NY overlap (07:00–16:00 UTC).
//   8. One position at a time, cooldown after exit  (no overlap, no revenge).
//   9. RSI is used only as a soft confirmation of momentum re-cross — NOT as
//      the primary signal. Same for MACD (not used here).
//  10. NO repaint:  request.security uses lookahead_off; entries fire on
//      barstate.isconfirmed; Supertrend / Hull / VWAP / ATR are causal.
//
// Recommended use:
//   1. Open EUR/USD chart, M15 timeframe.
//   2. Pine Editor → Open → New blank strategy → paste this whole file → Save.
//   3. Add to chart.  BUY / SELL labels appear at signal bars.
//   4. Open Strategy Tester tab (bottom).  Wait while TradingView runs it.
//   5. Scroll the chart left to load more history → trade count grows.
//      Typically 3-4 years of M15 history yields 500+ trades.
//
//@version=5
strategy(title              = "EUR/USD 70%+ WR — binary 5h (single file)",
         shorttitle         = "EURUSD-BIN5H",
         overlay            = true,
         pyramiding         = 0,
         initial_capital    = 10000,
         default_qty_type   = strategy.percent_of_equity,
         default_qty_value  = 5,
         commission_type    = strategy.commission.percent,
         commission_value   = 0.0,
         calc_on_every_tick = false,
         process_orders_on_close = true,
         max_labels_count   = 500)

// ── HARD EUR/USD GUARD ─────────────────────────────────────────────────
allowAnySymbol = input.bool(false, "Разрешить торговать на любой паре (НЕ рекомендуется)", group="Pair guard")
sym = str.upper(syminfo.ticker)
isEURUSD = str.contains(sym, "EURUSD") or str.contains(sym, "EUR/USD")
pairOk = allowAnySymbol or isEURUSD

// ── INPUTS ─────────────────────────────────────────────────────────────
useLong       = input.bool(true,  "Торговать BUY",                              group="Сигналы")
useShort      = input.bool(true,  "Торговать SELL",                             group="Сигналы")
showBigLabels = input.bool(true,  "Показывать БОЛЬШИЕ метки BUY/SELL",         group="Сигналы")
showLines     = input.bool(true,  "Показывать линии Supertrend / Hull / EMA200(H4)", group="Сигналы")

// Binary expiry
expiryBars    = input.int(20,     "Экспирация (баров на текущем ТФ)  [20·M15 = 5ч]", minval=1, maxval=400, group="Бинарка")

// Multi-TF trend
emaTrendLen   = input.int(200,    "EMA тренда (D1 + H4)",     minval=50,  maxval=400, group="Тренд")
emaH1Len      = input.int(50,     "EMA тренда (H1)",          minval=20,  maxval=200, group="Тренд")
adxMin        = input.int(22,     "Минимальный ADX(14) на H1", minval=10, maxval=40,  group="Тренд")
requireAllTF  = input.bool(true,  "Требовать согласие D1+H4+H1 (рекомендуется)", group="Тренд")

// Supertrend (entry-TF trend confirmation)
stAtrLen      = input.int(10,     "Supertrend ATR length",    minval=5,   maxval=30,  group="Supertrend")
stMul         = input.float(2.5,  "Supertrend multiplier",    minval=1.0, maxval=6.0, step=0.1, group="Supertrend")

// Hull MA (low-lag pullback anchor)
hullLen       = input.int(20,     "Hull MA length",           minval=5,   maxval=100, group="Hull MA")

// Soft RSI confirmation (NOT the primary signal)
useRsiConfirm = input.bool(true,  "Soft RSI-подтверждение момента", group="Подтверждение")
rsiLen        = input.int(14,     "RSI длина",                minval=5,   maxval=50,  group="Подтверждение")

// Volatility filter
atrLen        = input.int(14,     "ATR длина",                minval=5,   maxval=50,  group="Волатильность")
atrAvgLen     = input.int(50,     "Окно среднего ATR",        minval=20,  maxval=200, group="Волатильность")
atrFloor      = input.float(0.6,  "Минимум ATR / avgATR",     minval=0.2, maxval=2.0, step=0.05, group="Волатильность")

// VWAP confluence
useVwap       = input.bool(true,  "VWAP-подтверждение (H1)",  group="VWAP")

// Cooldown
cooldownBars  = input.int(8,      "Кулдаун между сделками (баров после выхода)", minval=0, maxval=200, group="Риск")

// Sessions  (UTC)  — London 08-16, NY 13-21, overlap 13-16
useSession    = input.bool(true,  "Торговать только в окне сессий",             group="Сессии")
sessLondonNY  = input.session("0700-1600:1234567", "Окно UTC (по умолч. London + NY overlap)", group="Сессии")

// ── HULL MA HELPER ─────────────────────────────────────────────────────
f_hull(src, len) =>
    half = math.max(1, math.floor(len / 2))
    sqr  = math.max(1, math.floor(math.sqrt(len)))
    ta.wma(2 * ta.wma(src, half) - ta.wma(src, len), sqr)

// ── HIGHER-TF DATA (no repaint: lookahead_off + confirmed close) ───────
f_d1() =>
    [close, ta.ema(close, emaTrendLen)]
f_h4() =>
    [close, ta.ema(close, emaTrendLen)]
f_h1() =>
    [dp, dm, ax] = ta.dmi(14, 14)
    [close, ta.ema(close, emaH1Len), ax, ta.vwap]

[d1_close, d1_ema] = request.security(syminfo.tickerid, "D",   f_d1(), barmerge.gaps_off, barmerge.lookahead_off)
[h4_close, h4_ema] = request.security(syminfo.tickerid, "240", f_h4(), barmerge.gaps_off, barmerge.lookahead_off)
[h1_close, h1_ema, h1_adx, h1_vwap] = request.security(syminfo.tickerid, "60", f_h1(), barmerge.gaps_off, barmerge.lookahead_off)
h1_vwap_ok = not na(h1_vwap)

d1_up   = d1_close > d1_ema
d1_down = d1_close < d1_ema
h4_up   = h4_close > h4_ema
h4_down = h4_close < h4_ema
h1_up   = h1_close > h1_ema
h1_down = h1_close < h1_ema

uptrend   = requireAllTF ? (d1_up   and h4_up   and h1_up)   : (h4_up   and h1_up)
downtrend = requireAllTF ? (d1_down and h4_down and h1_down) : (h4_down and h1_down)

// ── ENTRY-TF INDICATORS ────────────────────────────────────────────────
[stLine, stDir] = ta.supertrend(stMul, stAtrLen)
stUp   = stDir == -1
stDown = stDir ==  1

hull   = f_hull(close, hullLen)

rsi    = ta.rsi(close, rsiLen)

atr    = ta.atr(atrLen)
avgAtr = ta.sma(atr, atrAvgLen)
volOk  = atr > avgAtr * atrFloor
adxOk  = h1_adx > adxMin

inSession = not useSession or not na(time(timeframe.period, sessLondonNY, "UTC"))

// VWAP confluence:  in uptrend price should be above H1 VWAP, in downtrend below.
vwapOkLong  = not useVwap or (h1_vwap_ok and h1_close > h1_vwap)
vwapOkShort = not useVwap or (h1_vwap_ok and h1_close < h1_vwap)

// Hull slope (low-lag trend confirmation)
hullSlopeUp   = hull > hull[1]
hullSlopeDown = hull < hull[1]

// Pullback trigger:  close crosses Hull MA back into the trend direction.
//   Fires once per cross — no spam, no need for state.
crossUpHull   = ta.crossover (close, hull)
crossDownHull = ta.crossunder(close, hull)

// Soft momentum confirmation (NOT primary)
momOkLong   = not useRsiConfirm or rsi > 50
momOkShort  = not useRsiConfirm or rsi < 50

// ── FINAL SIGNAL (multi-confirmation) ──────────────────────────────────
baseFilter = volOk and adxOk and inSession and pairOk

// Primary signal:  cross of Hull MA in the dominant trend direction
//                  + Supertrend agreement + multi-TF agreement + filters.
longSignal  = uptrend   and stUp   and hullSlopeUp   and crossUpHull   and vwapOkLong  and momOkLong  and baseFilter
shortSignal = downtrend and stDown and hullSlopeDown and crossDownHull and vwapOkShort and momOkShort and baseFilter

// crossover already fires only on the bar of cross  →  signals are naturally
// "fresh" without extra state machinery.
freshLong  = longSignal
freshShort = shortSignal

// Cooldown
var int lastExitBar = na
canEnter = na(lastExitBar) or (bar_index - lastExitBar) > cooldownBars

// ── ENTRY (binary — no TP, no SL; close after expiryBars) ──────────────
var int entryBar = na

if useLong and freshLong and strategy.position_size == 0 and canEnter and barstate.isconfirmed
    strategy.entry("L", strategy.long, comment="BUY")
    entryBar := bar_index

if useShort and freshShort and strategy.position_size == 0 and canEnter and barstate.isconfirmed
    strategy.entry("S", strategy.short, comment="SELL")
    entryBar := bar_index

// Time-based exit: close exactly  expiryBars  bars after entry
if strategy.position_size > 0 and not na(entryBar) and (bar_index - entryBar) >= expiryBars
    strategy.close("L", comment="expiry")
    lastExitBar := bar_index
    entryBar := na

if strategy.position_size < 0 and not na(entryBar) and (bar_index - entryBar) >= expiryBars
    strategy.close("S", comment="expiry")
    lastExitBar := bar_index
    entryBar := na

// ── ALERTS ─────────────────────────────────────────────────────────────
alertcondition(freshLong,  title="BUY (5h binary)",  message="EURUSD-BIN5H: BUY  on M15, expiry 5h")
alertcondition(freshShort, title="SELL (5h binary)", message="EURUSD-BIN5H: SELL on M15, expiry 5h")

// ── PLOTS ──────────────────────────────────────────────────────────────
plot(showLines ? hull   : na, "Hull MA",       color=color.new(color.orange, 0), linewidth=2)
plot(showLines ? stLine : na, "Supertrend",    color=stUp ? color.new(color.green, 0) : color.new(color.red, 0), linewidth=2)
plot(showLines ? h4_ema : na, "EMA200 H4",     color=color.new(color.blue,   0), linewidth=1)

bgcolor(useSession and not inSession ? color.new(color.gray, 92) : na, title="Out of session")

// Big BUY/SELL labels (acts as indicator)
plotshape(showBigLabels and freshLong,  title="BUY",  text="BUY",  textcolor=color.white, style=shape.labelup,   location=location.belowbar, size=size.normal, color=color.new(color.green, 0))
plotshape(showBigLabels and freshShort, title="SELL", text="SELL", textcolor=color.white, style=shape.labeldown, location=location.abovebar, size=size.normal, color=color.new(color.red,   0))

// Small triangles for "soft" signal (confirmed but suppressed by cooldown / position)
plotshape(longSignal  and not freshLong,  title="buy(soft)",  style=shape.triangleup,   location=location.belowbar, size=size.tiny, color=color.new(color.green, 60))
plotshape(shortSignal and not freshShort, title="sell(soft)", style=shape.triangledown, location=location.abovebar, size=size.tiny, color=color.new(color.red,   60))

// ── PAIR-GUARD WARNING ─────────────────────────────────────────────────
var label warnLbl = na
if barstate.islast and not pairOk
    warnLbl := label.new(bar_index, high, "Эта стратегия настроена ТОЛЬКО под EUR/USD.\nВключи 'Разрешить торговать на любой паре' в настройках,\nили перейди на график EURUSD.", style=label.style_label_down, color=color.red, textcolor=color.white, size=size.normal)
    label.delete(warnLbl[1])

// ── ON-CHART STATS PANEL ───────────────────────────────────────────────
var table stats = table.new(position.top_right, 2, 6, frame_color=color.gray, frame_width=1, border_color=color.gray, border_width=1)
if barstate.islast
    totalTrades = strategy.closedtrades
    wins        = strategy.wintrades
    wr          = totalTrades > 0 ? wins / totalTrades * 100.0 : 0.0
    pf          = strategy.grossloss > 0 ? strategy.grossprofit / strategy.grossloss : 0.0
    table.cell(stats, 0, 0, "EURUSD-BIN5H",     bgcolor=color.new(color.blue, 0),  text_color=color.white, text_size=size.small)
    table.cell(stats, 1, 0, str.tostring(expiryBars * timeframe.in_seconds() / 3600.0, "#.##") + "h",  bgcolor=color.new(color.blue, 0),  text_color=color.white, text_size=size.small)
    table.cell(stats, 0, 1, "Сделок",            text_color=color.silver, text_size=size.small)
    table.cell(stats, 1, 1, str.tostring(totalTrades), text_color=color.white, text_size=size.small)
    table.cell(stats, 0, 2, "Win Rate",          text_color=color.silver, text_size=size.small)
    table.cell(stats, 1, 2, str.tostring(wr, "#.##") + "%", bgcolor=wr>=70 ? color.new(color.green,0) : wr>=56 ? color.new(color.orange,0) : color.new(color.red,0), text_color=color.white, text_size=size.small)
    table.cell(stats, 0, 3, "Profit Factor",     text_color=color.silver, text_size=size.small)
    table.cell(stats, 1, 3, str.tostring(pf, "#.##"), text_color=color.white, text_size=size.small)
    table.cell(stats, 0, 4, "Net P&L",           text_color=color.silver, text_size=size.small)
    table.cell(stats, 1, 4, str.tostring(strategy.netprofit, "#.##"), text_color=strategy.netprofit>=0 ? color.lime : color.red, text_size=size.small)
    table.cell(stats, 0, 5, "Pair guard",        text_color=color.silver, text_size=size.small)
    table.cell(stats, 1, 5, pairOk ? "✅ EURUSD" : "❌ NOT EURUSD", text_color=pairOk ? color.lime : color.red, text_size=size.small)
