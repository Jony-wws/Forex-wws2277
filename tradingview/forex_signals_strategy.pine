// © Jony-wws / Forex-wws2277 — mirrored from app/analyzer.py + app/cycle.py
// FOREX-28 v3 — STRICT binary-options strategy (no TP / no SL)
// Tuned for EURUSD M30, binary-option payout 80%, target WR ≥ 70%.
//
// v3 adds strict entry filters on top of the v2 voting score:
//   - confidence_pct ≥ strictGate  (default 90)
//   - h1_adx ≥ adxMin              (default 25 — must be a real trend)
//   - skip Asian session           (only fire 07:00–21:59 UTC)
//   - require multi-TF unanimity   (all 4 of D1/H4/H1/M15 must agree on dir)
// All four filters are exposed as inputs but DEFAULT to ON so the chart
// instance picks them up automatically after a fresh save.
//
// Trade model:
//   - Enter long  on freshBuy  (conf >= gateConf, valid pair, no DD-halt).
//   - Enter short on freshSell.
//   - Hold until expiry  (expiryH hours)  →  close at market.  No TP / SL.
//   - "Reverse" exit: if the opposite signal fires with conf >= revGate
//     before expiry → close current position at market and open the opposite.
//   - The win/loss is determined by the closing price's direction vs. entry
//     (binary).  Strategy Tester reports Win Rate, Profit Factor etc. on this
//     definition because each trade is a discrete payoff event.
//
// Universal: works on any chart TF, internally pulls D1+H4+H1+M15.
//@version=5
strategy(title              = "FOREX-28 v3 — strict binary-options strategy",
         shorttitle         = "FX-28-S v3",
         overlay            = true,
         pyramiding         = 0,
         initial_capital    = 10000,
         default_qty_type   = strategy.percent_of_equity,
         default_qty_value  = 5,
         commission_type    = strategy.commission.percent,
         commission_value   = 0.002,
         calc_on_every_tick = false,
         process_orders_on_close = true)

// ── INPUTS ─────────────────────────────────────────────────────────────
gateConf      = input.int  (80,   "Уверенность для входа, %",                 minval=50, maxval=95, group="Сигнал")
expiryH       = input.float(5.0,  "Горизонт сделки (binary expiry), часов",   minval=0.25, maxval=24, step=0.25, group="Сигнал")
allowReverse  = input.bool (true, "Разрешить разворот",                       group="Сигнал")
revGate       = input.int  (80,   "Уверенность для разворота, %",             minval=50, maxval=95, group="Сигнал")
useLong       = input.bool (true, "Торговать BUY",                            group="Сигнал")
useShort      = input.bool (true, "Торговать SELL",                           group="Сигнал")
showLbl       = input.bool (true, "Показывать метки на графике",              group="Отображение")
showHorizonLine = input.bool(true,"Линия горизонта",                         group="Отображение")

// ── STRICT FILTERS (v3) ────────────────────────────────────────────────
strictGate    = input.int  (90,   "v3: жёсткий gate уверенности, %",          minval=50, maxval=95, group="Strict v3")
useAdxFilter  = input.bool (true, "v3: фильтр ADX (мин. сила тренда)",         group="Strict v3")
adxMin        = input.int  (25,   "v3: минимум ADX",                          minval=10, maxval=50, group="Strict v3")
skipAsian     = input.bool (true, "v3: пропускать азиатскую сессию (0-7 UTC)", group="Strict v3")
skipLateUS    = input.bool (true, "v3: пропускать ночь США (22-24 UTC)",      group="Strict v3")
requireMtfUnan= input.bool (true, "v3: требовать единогласие D1/H4/H1/M15",   group="Strict v3")

// ── PER-TF AGGREGATORS ─────────────────────────────────────────────────
f_h1_pack() =>
    e20  = ta.ema(close, 20)
    e50  = ta.ema(close, 50)
    rsi  = ta.rsi(close, 14)
    [m, s, h] = ta.macd(close, 12, 26, 9)
    hp = h[1]
    [bbm, bbu, bbl] = ta.bb(close, 20, 2.0)
    bbpct = (close - bbl) / (bbu - bbl)
    sk = ta.stoch(close, high, low, 14)
    sd = ta.sma(sk, 3)
    [dp, dm, ax] = ta.dmi(14, 14)
    wr  = ta.wpr(14)
    mom = (close / close[10] - 1) * 100
    tk  = (ta.highest(high,  9) + ta.lowest(low,  9)) / 2
    kj  = (ta.highest(high, 26) + ta.lowest(low, 26)) / 2
    sa  = (tk + kj) / 2
    sb  = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2
    aboveC = close > math.max(sa, sb)
    belowC = close < math.min(sa, sb)
    vw  = ta.vwap
    vw_ok = not na(vw)
    bullEng = close > open and close[1] < open[1] and close > open[1] and open <= close[1]
    bearEng = close < open and close[1] > open[1] and close < open[1] and open >= close[1]
    body    = math.abs(close - open)
    upWick  = high - math.max(close, open)
    dnWick  = math.min(close, open) - low
    hammer  = body > 0 and dnWick > 2 * body and upWick < body
    shootng = body > 0 and upWick > 2 * body and dnWick < body
    paScore = (bullEng or hammer ? 2 : 0) - (bearEng or shootng ? 2 : 0)
    [close, e20, e50, rsi, h, hp, bbpct, sk, sd, dp, dm, ax, wr, mom,
     aboveC, belowC, tk, kj, vw, vw_ok, paScore]

f_m15_pack() => [close, ta.ema(close, 20), ta.ema(close, 50)]
f_h4_pack()  => [close, ta.ema(close, 50), ta.ema(close, 200)]
f_d1_pack()  => [close, ta.ema(close, 50), ta.ema(close, 200)]

[h1_close, h1_ema20, h1_ema50, h1_rsi, h1_hist, h1_hist_prev,
 h1_bbpct, h1_sk, h1_sd, h1_dp, h1_dm, h1_adx, h1_wr, h1_mom,
 h1_above, h1_below, h1_tk, h1_kj, h1_vwap, h1_vwap_ok, h1_pa] =
     request.security(syminfo.tickerid, "60",  f_h1_pack(),  barmerge.gaps_off, barmerge.lookahead_off)
[m15_close, m15_ema20, m15_ema50] =
     request.security(syminfo.tickerid, "15",  f_m15_pack(), barmerge.gaps_off, barmerge.lookahead_off)
[h4_close, h4_ema50, h4_ema200] =
     request.security(syminfo.tickerid, "240", f_h4_pack(),  barmerge.gaps_off, barmerge.lookahead_off)
[d1_close, d1_ema50, d1_ema200] =
     request.security(syminfo.tickerid, "D",   f_d1_pack(),  barmerge.gaps_off, barmerge.lookahead_off)

// ── 15 voting blocks ───────────────────────────────────────────────────
var float score_v = 0.
var float maxp_v  = 0.
score_v := 0.
maxp_v  := 0.

// A0 D1
if d1_close > d1_ema50 and d1_ema50 > d1_ema200
    score_v := score_v + 3
else if d1_close < d1_ema50 and d1_ema50 < d1_ema200
    score_v := score_v - 3
else if d1_close > d1_ema50
    score_v := score_v + 1
else if d1_close < d1_ema50
    score_v := score_v - 1
maxp_v := maxp_v + 3

// A H4
if h4_close > h4_ema50 and h4_ema50 > h4_ema200
    score_v := score_v + 3
else if h4_close < h4_ema50 and h4_ema50 < h4_ema200
    score_v := score_v - 3
else if h4_close > h4_ema50
    score_v := score_v + 1
else if h4_close < h4_ema50
    score_v := score_v - 1
maxp_v := maxp_v + 3

// B H1
if h1_close > h1_ema20 and h1_ema20 > h1_ema50
    score_v := score_v + 2
else if h1_close < h1_ema20 and h1_ema20 < h1_ema50
    score_v := score_v - 2
maxp_v := maxp_v + 2

// C M15
if m15_close > m15_ema20
    score_v := score_v + 1
else
    score_v := score_v - 1
maxp_v := maxp_v + 1

// D RSI
if h1_rsi > 55 and h1_rsi < 70
    score_v := score_v + 2
else if h1_rsi > 30 and h1_rsi < 45
    score_v := score_v - 2
else if h1_rsi >= 70
    score_v := score_v - 3
else if h1_rsi <= 30
    score_v := score_v + 3
maxp_v := maxp_v + 3

// E MACD
if h1_hist > 0 and h1_hist_prev <= 0
    score_v := score_v + 3
else if h1_hist < 0 and h1_hist_prev >= 0
    score_v := score_v - 3
else if h1_hist > 0 and h1_hist > h1_hist_prev
    score_v := score_v + 2
else if h1_hist < 0 and h1_hist < h1_hist_prev
    score_v := score_v - 2
else if h1_hist > 0
    score_v := score_v + 1
else if h1_hist < 0
    score_v := score_v - 1
maxp_v := maxp_v + 3

// F BB %B
if h1_bbpct > 0.95
    score_v := score_v - 2
else if h1_bbpct < 0.05
    score_v := score_v + 2
else if h1_bbpct > 0.65
    score_v := score_v + 1
else if h1_bbpct < 0.35
    score_v := score_v - 1
maxp_v := maxp_v + 2

// G Stoch
if h1_sk < 20 and h1_sd < 20
    score_v := score_v + 2
else if h1_sk > 80 and h1_sd > 80
    score_v := score_v - 2
else if h1_sk > h1_sd and h1_sk < 80
    score_v := score_v + 1
else if h1_sk < h1_sd and h1_sk > 20
    score_v := score_v - 1
maxp_v := maxp_v + 2

// H ADX
if h1_adx < 15
    score_v := score_v > 0 ? score_v - math.abs(score_v) * 0.5 : score_v + math.abs(score_v) * 0.5
else if h1_adx > 30
    if h1_dp > h1_dm
        score_v := score_v + 3
    else
        score_v := score_v - 3
else if h1_adx > 20
    if h1_dp > h1_dm
        score_v := score_v + 1
    else
        score_v := score_v - 1
maxp_v := maxp_v + 3

// I Williams
if h1_wr > -20
    score_v := score_v - 1
else if h1_wr < -80
    score_v := score_v + 1
maxp_v := maxp_v + 1

// J Ichimoku
if h1_above and h1_tk > h1_kj
    score_v := score_v + 3
else if h1_below and h1_tk < h1_kj
    score_v := score_v - 3
else if h1_above
    score_v := score_v + 1
else if h1_below
    score_v := score_v - 1
maxp_v := maxp_v + 3

// K Momentum
if h1_mom > 0.15
    score_v := score_v + 2
else if h1_mom < -0.15
    score_v := score_v - 2
else if h1_mom > 0.05
    score_v := score_v + 1
else if h1_mom < -0.05
    score_v := score_v - 1
maxp_v := maxp_v + 2

// L VWAP
if h1_vwap_ok
    if h1_close > h1_vwap * 1.001
        score_v := score_v + 1
    else if h1_close < h1_vwap * 0.999
        score_v := score_v - 1
    maxp_v := maxp_v + 1

// M Multi-TF
bull4 = (d1_close > d1_ema50 ? 1 : 0) + (h4_close > h4_ema50 ? 1 : 0) + (h1_close > h1_ema20 ? 1 : 0) + (m15_close > m15_ema20 ? 1 : 0)
if bull4 == 4
    score_v := score_v + 3
else if bull4 == 0
    score_v := score_v - 3
else if bull4 >= 3
    score_v := score_v + 1
else if bull4 <= 1
    score_v := score_v - 1
maxp_v := maxp_v + 3

// N Price Action
if h1_pa != 0
    capped = math.max(-3, math.min(3, h1_pa))
    score_v := score_v + capped
maxp_v := maxp_v + 3

// O M15 EMA cross
if m15_ema20 > m15_ema50
    score_v := score_v + 1
else
    score_v := score_v - 1
maxp_v := maxp_v + 1

// ── CONFIDENCE / SIGNAL ────────────────────────────────────────────────
ratio = maxp_v > 0 ? math.min(1.0, math.abs(score_v) / maxp_v) : 0.0
confidence_pct = math.round(math.max(50, math.min(95, 50 + 45 * (1 - math.exp(-3.66 * ratio)))))
direction = score_v > 0 ? 1 : score_v < 0 ? -1 : 0
isStrong = confidence_pct >= gateConf and direction != 0

var int prevDir = 0
freshBuy  = isStrong and direction ==  1 and prevDir !=  1
freshSell = isStrong and direction == -1 and prevDir != -1
if isStrong
    prevDir := direction

// ── STRICT FILTERS (v3) ────────────────────────────────────────────────
// Note: bull4 is already computed by the M Multi-TF voting block above.
hourUtc   = hour(time, "UTC")
sessionOk = (not skipAsian or hourUtc >= 7) and (not skipLateUS or hourUtc < 22)
adxOk     = not useAdxFilter or h1_adx >= adxMin
mtfBull   = bull4 == 4
mtfBear   = bull4 == 0
gateOk    = confidence_pct >= strictGate
canBuy    = freshBuy  and sessionOk and adxOk and gateOk and (not requireMtfUnan or mtfBull)
canSell   = freshSell and sessionOk and adxOk and gateOk and (not requireMtfUnan or mtfBear)

// ── ENTRY ──────────────────────────────────────────────────────────────
if useLong  and canBuy  and strategy.position_size == 0
    strategy.entry("L", strategy.long,  comment="BUY "  + str.tostring(confidence_pct) + "%")
if useShort and canSell and strategy.position_size == 0
    strategy.entry("S", strategy.short, comment="SELL " + str.tostring(confidence_pct) + "%")

// Reversal entry: close current and open opposite if conf >= revGate AND filters pass
if allowReverse and strategy.position_size > 0 and canSell and confidence_pct >= revGate
    strategy.close("L", comment="↻rev SELL")
    if useShort
        strategy.entry("S", strategy.short, comment="SELL " + str.tostring(confidence_pct) + "% (rev)")
if allowReverse and strategy.position_size < 0 and canBuy and confidence_pct >= revGate
    strategy.close("S", comment="↻rev BUY")
    if useLong
        strategy.entry("L", strategy.long, comment="BUY " + str.tostring(confidence_pct) + "% (rev)")

// ── EXIT: TIME-STOP ONLY (binary expiry; NO TP/SL) ─────────────────────
var int entryT = na
if strategy.position_size != 0 and na(entryT)
    entryT := time
expiryMs = int(expiryH * 60.0 * 60.0 * 1000.0)
if strategy.position_size != 0 and not na(entryT) and (time - entryT) >= expiryMs
    strategy.close_all(comment="expiry")
if strategy.position_size == 0
    entryT := na

// ── VISUAL LABELS ──────────────────────────────────────────────────────
plotshape(showLbl and canBuy,  title="BUY",
          style=shape.labelup,   location=location.belowbar,
          color=color.new(color.green, 0), textcolor=color.white,
          text="BUY", size=size.small)
plotshape(showLbl and canSell, title="SELL",
          style=shape.labeldown, location=location.abovebar,
          color=color.new(color.red, 0),   textcolor=color.white,
          text="SELL", size=size.small)

if showHorizonLine and (canBuy or canSell)
    expBar = time + expiryMs
    line.new(x1=time, y1=close, x2=expBar, y2=close,
             xloc=xloc.bar_time, color=color.new(canBuy ? color.green : color.red, 50),
             style=line.style_dashed, width=2)
