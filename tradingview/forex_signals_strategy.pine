// © Jony-wws / Forex-wws2277 — mirrored from app/analyzer.py + app/cycle.py
// Backtestable strategy: same multi-TF signal as the indicator,
// wired into TradingView Strategy Tester for honest win-rate stats.
//
// Trading rule (binary, mirrors cycle.py):
//   On a fresh BUY signal (conf >= gate)  → enter long.
//     Exit when: TP +0.10% (win) | SL −0.10% (loss) | Horizon hours elapsed (close at market).
//   Same for SELL (mirrored).  No pyramiding.
//@version=5
strategy(title              = "FOREX-28 Strategy — 0.10% binary, 5h/24h horizon",
         shorttitle         = "FX-28-S",
         overlay            = true,
         pyramiding         = 0,
         initial_capital    = 10000,
         default_qty_type   = strategy.percent_of_equity,
         default_qty_value  = 5,
         commission_type    = strategy.commission.percent,
         commission_value   = 0.002,
         calc_on_every_tick = false,
         process_orders_on_close = true)

// ── INPUTS ─────────────────────────────────────────────────────────────
gateConf = input.int  (80,   "Уверенность для входа, %", minval=50, maxval=95)
horizonH = input.int  (5,    "Горизонт сделки, часов",   minval=1,  maxval=72)
winPct   = input.float(0.10, "Порог TP / SL, %",         minval=0.01, maxval=2.0, step=0.01)
useLong  = input.bool (true, "Торговать BUY")
useShort = input.bool (true, "Торговать SELL")
showLbl  = input.bool (true, "Показывать метки на графике")

// ── PER-TF AGGREGATORS ─────────────────────────────────────────────────
f_h1_pack() =>
    e20  = ta.ema(close, 20)
    e50  = ta.ema(close, 50)
    rsi  = ta.rsi(close, 14)
    [m, s, h] = ta.macd(close, 12, 26, 9)
    hp = h[1]
    [bbm, bbu, bbl] = ta.bb(close, 20, 2.0)
    bbpct = (close - bbl) / (bbu - bbl)
    sk = ta.stoch(close, high, low, 14)
    sd = ta.sma(sk, 3)
    [dp, dm, ax] = ta.dmi(14, 14)
    wr = ta.wpr(14)
    mom = (close / close[10] - 1) * 100
    [close, e20, e50, rsi, h, hp, bbpct, sk, sd, dp, dm, ax, wr, mom]

f_m15_pack() =>
    [close, ta.ema(close, 20), ta.ema(close, 50)]

f_h4_pack() =>
    [close, ta.ema(close, 50), ta.ema(close, 200)]

f_d1_pack() =>
    [close, ta.ema(close, 50), ta.ema(close, 200)]

[h1_close, h1_ema20, h1_ema50, h1_rsi, h1_hist, h1_hist_prev,
 h1_bbpct, h1_sk, h1_sd, h1_dp, h1_dm, h1_adx, h1_wr, h1_mom] =
     request.security(syminfo.tickerid, "60",  f_h1_pack(),  barmerge.gaps_off, barmerge.lookahead_off)
[m15_close, m15_ema20, m15_ema50] =
     request.security(syminfo.tickerid, "15",  f_m15_pack(), barmerge.gaps_off, barmerge.lookahead_off)
[h4_close, h4_ema50, h4_ema200] =
     request.security(syminfo.tickerid, "240", f_h4_pack(),  barmerge.gaps_off, barmerge.lookahead_off)
[d1_close, d1_ema50, d1_ema200] =
     request.security(syminfo.tickerid, "D",   f_d1_pack(),  barmerge.gaps_off, barmerge.lookahead_off)

// ── SCORE / MAX ────────────────────────────────────────────────────────
var float score_v = 0.
var float maxp_v  = 0.
score_v := 0.
maxp_v  := 0.

// A0. D1 trend  (weight 3)
if d1_close > d1_ema50 and d1_ema50 > d1_ema200
    score_v := score_v + 3
else if d1_close < d1_ema50 and d1_ema50 < d1_ema200
    score_v := score_v - 3
else if d1_close > d1_ema50
    score_v := score_v + 1
else if d1_close < d1_ema50
    score_v := score_v - 1
maxp_v := maxp_v + 3

// A. H4 trend  (weight 3)
if h4_close > h4_ema50 and h4_ema50 > h4_ema200
    score_v := score_v + 3
else if h4_close < h4_ema50 and h4_ema50 < h4_ema200
    score_v := score_v - 3
else if h4_close > h4_ema50
    score_v := score_v + 1
else if h4_close < h4_ema50
    score_v := score_v - 1
maxp_v := maxp_v + 3

// B. H1 confirmation  (weight 2)
if h1_close > h1_ema20 and h1_ema20 > h1_ema50
    score_v := score_v + 2
else if h1_close < h1_ema20 and h1_ema20 < h1_ema50
    score_v := score_v - 2
maxp_v := maxp_v + 2

// C. M15 entry  (weight 1)
if m15_close > m15_ema20
    score_v := score_v + 1
else
    score_v := score_v - 1
maxp_v := maxp_v + 1

// D. RSI on H1  (weight 3)
if h1_rsi > 55 and h1_rsi < 70
    score_v := score_v + 2
else if h1_rsi > 30 and h1_rsi < 45
    score_v := score_v - 2
else if h1_rsi >= 70
    score_v := score_v - 3
else if h1_rsi <= 30
    score_v := score_v + 3
maxp_v := maxp_v + 3

// E. MACD on H1  (weight 3)
if h1_hist > 0 and h1_hist_prev <= 0
    score_v := score_v + 3
else if h1_hist < 0 and h1_hist_prev >= 0
    score_v := score_v - 3
else if h1_hist > 0 and h1_hist > h1_hist_prev
    score_v := score_v + 2
else if h1_hist < 0 and h1_hist < h1_hist_prev
    score_v := score_v - 2
else if h1_hist > 0
    score_v := score_v + 1
else if h1_hist < 0
    score_v := score_v - 1
maxp_v := maxp_v + 3

// F. Bollinger %B on H1  (weight 2)
if h1_bbpct > 0.95
    score_v := score_v - 2
else if h1_bbpct < 0.05
    score_v := score_v + 2
else if h1_bbpct > 0.65
    score_v := score_v + 1
else if h1_bbpct < 0.35
    score_v := score_v - 1
maxp_v := maxp_v + 2

// G. Stochastic on H1  (weight 2)
if h1_sk < 20 and h1_sd < 20
    score_v := score_v + 2
else if h1_sk > 80 and h1_sd > 80
    score_v := score_v - 2
else if h1_sk > h1_sd and h1_sk < 80
    score_v := score_v + 1
else if h1_sk < h1_sd and h1_sk > 20
    score_v := score_v - 1
maxp_v := maxp_v + 2

// H. ADX on H1  (weight 3)
if h1_adx < 15
    score_v := score_v > 0 ? score_v - math.abs(score_v) * 0.5 : score_v + math.abs(score_v) * 0.5
else if h1_adx > 30
    if h1_dp > h1_dm
        score_v := score_v + 3
    else
        score_v := score_v - 3
else if h1_adx > 20
    if h1_dp > h1_dm
        score_v := score_v + 1
    else
        score_v := score_v - 1
maxp_v := maxp_v + 3

// I. Williams %R on H1  (weight 1)
if h1_wr > -20
    score_v := score_v - 1
else if h1_wr < -80
    score_v := score_v + 1
maxp_v := maxp_v + 1

// K. Momentum on H1 (10-bar %)  (weight 2)
if h1_mom > 0.15
    score_v := score_v + 2
else if h1_mom < -0.15
    score_v := score_v - 2
else if h1_mom > 0.05
    score_v := score_v + 1
else if h1_mom < -0.05
    score_v := score_v - 1
maxp_v := maxp_v + 2

// M. Multi-TF agreement (D1+H4+H1+M15)  (weight 3)
bull4 = (d1_close > d1_ema50 ? 1 : 0) + (h4_close > h4_ema50 ? 1 : 0) + (h1_close > h1_ema20 ? 1 : 0) + (m15_close > m15_ema20 ? 1 : 0)
if bull4 == 4
    score_v := score_v + 3
else if bull4 == 0
    score_v := score_v - 3
else if bull4 >= 3
    score_v := score_v + 1
else if bull4 <= 1
    score_v := score_v - 1
maxp_v := maxp_v + 3

// O. M15 EMA20/50 cross  (weight 1)
if m15_ema20 > m15_ema50
    score_v := score_v + 1
else
    score_v := score_v - 1
maxp_v := maxp_v + 1

// ── CONFIDENCE / SIGNAL ────────────────────────────────────────────────
ratio = maxp_v > 0 ? math.min(1.0, math.abs(score_v) / maxp_v) : 0.0
confidence_pct = math.round(math.max(50, math.min(95, 50 + 45 * (1 - math.exp(-3.66 * ratio)))))
direction = score_v > 0 ? "BUY" : score_v < 0 ? "SELL" : "—"
isStrong  = confidence_pct >= gateConf and direction != "—"

var string prevDir = "—"
freshBuy  = isStrong and direction == "BUY"  and prevDir != "BUY"
freshSell = isStrong and direction == "SELL" and prevDir != "SELL"
if isStrong
    prevDir := direction

// ── ENTRY ──────────────────────────────────────────────────────────────
if useLong  and freshBuy  and strategy.position_size == 0
    strategy.entry("L", strategy.long,  comment="BUY "  + str.tostring(confidence_pct) + "%")
if useShort and freshSell and strategy.position_size == 0
    strategy.entry("S", strategy.short, comment="SELL " + str.tostring(confidence_pct) + "%")

// ── EXIT: TP / SL / TIME-STOP ──────────────────────────────────────────
var float entryP = na
var int   entryT = na

if strategy.position_size != 0 and na(entryP)
    entryP := strategy.position_avg_price
    entryT := time

if strategy.position_size > 0
    tp = entryP * (1 + winPct / 100)
    sl = entryP * (1 - winPct / 100)
    strategy.exit("Lx", "L", limit=tp, stop=sl)

if strategy.position_size < 0
    tp = entryP * (1 - winPct / 100)
    sl = entryP * (1 + winPct / 100)
    strategy.exit("Sx", "S", limit=tp, stop=sl)

horizonMs = horizonH * 60 * 60 * 1000
if strategy.position_size != 0 and not na(entryT) and (time - entryT) >= horizonMs
    strategy.close_all(comment="time-stop")

if strategy.position_size == 0
    entryP := na
    entryT := na

// ── VISUAL LABELS ──────────────────────────────────────────────────────
plotshape(showLbl and freshBuy,  title="BUY",
          style=shape.labelup,   location=location.belowbar,
          color=color.new(color.green, 0), textcolor=color.white,
          text="BUY", size=size.small)

plotshape(showLbl and freshSell, title="SELL",
          style=shape.labeldown, location=location.abovebar,
          color=color.new(color.red, 0),   textcolor=color.white,
          text="SELL", size=size.small)
