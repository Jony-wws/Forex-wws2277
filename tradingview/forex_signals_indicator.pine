// © Jony-wws / Forex-wws2277 — mirrored from app/analyzer.py
// Multi-timeframe BUY/SELL signal indicator for forex.
// M15 + H1 + H4 + D1 voting; signal fires only when confidence >= 80 %.
// Apply on ANY chart timeframe — script always pulls D1/H4/H1/M15 itself.
//@version=5
indicator(title     = "FOREX-28 Signals — Multi-TF (D1+H4+H1+M15)",
          shorttitle= "FX-28",
          overlay   = true,
          max_labels_count = 500)

// ── INPUTS ─────────────────────────────────────────────────────────────
gateConf      = input.int(80,  "Минимальная уверенность для сигнала, %", minval=50, maxval=95)
showInfoTable = input.bool(true,"Показать таблицу с уверенностью")
showSignals   = input.bool(true,"Показывать метки BUY / SELL")

// ── PER-TF AGGREGATOR FUNCTIONS  (each runs in security() context) ─────
// All H1 indicators in one call — keeps us well under the 40-security limit.
f_h1_pack() =>
    e20  = ta.ema(close, 20)
    e50  = ta.ema(close, 50)
    rsi  = ta.rsi(close, 14)
    [m, s, h] = ta.macd(close, 12, 26, 9)
    hp = h[1]
    [bbm, bbu, bbl] = ta.bb(close, 20, 2.0)
    bbpct = (close - bbl) / (bbu - bbl)
    sk = ta.stoch(close, high, low, 14)
    sd = ta.sma(sk, 3)
    [dp, dm, ax] = ta.dmi(14, 14)
    wr = ta.wpr(14)
    mom = (close / close[10] - 1) * 100
    [close, e20, e50, rsi, h, hp, bbpct, sk, sd, dp, dm, ax, wr, mom]

f_m15_pack() =>
    e20 = ta.ema(close, 20)
    e50 = ta.ema(close, 50)
    [close, e20, e50]

f_h4_pack() =>
    e50  = ta.ema(close, 50)
    e200 = ta.ema(close, 200)
    [close, e50, e200]

f_d1_pack() =>
    e50  = ta.ema(close, 50)
    e200 = ta.ema(close, 200)
    [close, e50, e200]

// ── PULL HTF DATA (4 security calls total) ─────────────────────────────
[h1_close, h1_ema20, h1_ema50, h1_rsi, h1_hist, h1_hist_prev,
 h1_bbpct, h1_sk, h1_sd, h1_dp, h1_dm, h1_adx, h1_wr, h1_mom] =
     request.security(syminfo.tickerid, "60", f_h1_pack(), barmerge.gaps_off, barmerge.lookahead_off)

[m15_close, m15_ema20, m15_ema50] =
     request.security(syminfo.tickerid, "15", f_m15_pack(), barmerge.gaps_off, barmerge.lookahead_off)

[h4_close, h4_ema50, h4_ema200] =
     request.security(syminfo.tickerid, "240", f_h4_pack(), barmerge.gaps_off, barmerge.lookahead_off)

[d1_close, d1_ema50, d1_ema200] =
     request.security(syminfo.tickerid, "D", f_d1_pack(), barmerge.gaps_off, barmerge.lookahead_off)

// ── SCORE / MAX POSSIBLE ───────────────────────────────────────────────
var float score_v = 0.
var float maxp_v  = 0.

score_v := 0.
maxp_v  := 0.

// A0. D1 trend  (weight 3)
if d1_close > d1_ema50 and d1_ema50 > d1_ema200
    score_v := score_v + 3
else if d1_close < d1_ema50 and d1_ema50 < d1_ema200
    score_v := score_v - 3
else if d1_close > d1_ema50
    score_v := score_v + 1
else if d1_close < d1_ema50
    score_v := score_v - 1
maxp_v := maxp_v + 3

// A. H4 trend  (weight 3)
if h4_close > h4_ema50 and h4_ema50 > h4_ema200
    score_v := score_v + 3
else if h4_close < h4_ema50 and h4_ema50 < h4_ema200
    score_v := score_v - 3
else if h4_close > h4_ema50
    score_v := score_v + 1
else if h4_close < h4_ema50
    score_v := score_v - 1
maxp_v := maxp_v + 3

// B. H1 confirmation  (weight 2)
if h1_close > h1_ema20 and h1_ema20 > h1_ema50
    score_v := score_v + 2
else if h1_close < h1_ema20 and h1_ema20 < h1_ema50
    score_v := score_v - 2
maxp_v := maxp_v + 2

// C. M15 entry  (weight 1)
if m15_close > m15_ema20
    score_v := score_v + 1
else
    score_v := score_v - 1
maxp_v := maxp_v + 1

// D. RSI on H1  (weight 3)
if h1_rsi > 55 and h1_rsi < 70
    score_v := score_v + 2
else if h1_rsi > 30 and h1_rsi < 45
    score_v := score_v - 2
else if h1_rsi >= 70
    score_v := score_v - 3
else if h1_rsi <= 30
    score_v := score_v + 3
maxp_v := maxp_v + 3

// E. MACD on H1  (weight 3)
if h1_hist > 0 and h1_hist_prev <= 0
    score_v := score_v + 3
else if h1_hist < 0 and h1_hist_prev >= 0
    score_v := score_v - 3
else if h1_hist > 0 and h1_hist > h1_hist_prev
    score_v := score_v + 2
else if h1_hist < 0 and h1_hist < h1_hist_prev
    score_v := score_v - 2
else if h1_hist > 0
    score_v := score_v + 1
else if h1_hist < 0
    score_v := score_v - 1
maxp_v := maxp_v + 3

// F. Bollinger %B on H1  (weight 2)
if h1_bbpct > 0.95
    score_v := score_v - 2
else if h1_bbpct < 0.05
    score_v := score_v + 2
else if h1_bbpct > 0.65
    score_v := score_v + 1
else if h1_bbpct < 0.35
    score_v := score_v - 1
maxp_v := maxp_v + 2

// G. Stochastic on H1  (weight 2)
if h1_sk < 20 and h1_sd < 20
    score_v := score_v + 2
else if h1_sk > 80 and h1_sd > 80
    score_v := score_v - 2
else if h1_sk > h1_sd and h1_sk < 80
    score_v := score_v + 1
else if h1_sk < h1_sd and h1_sk > 20
    score_v := score_v - 1
maxp_v := maxp_v + 2

// H. ADX on H1  (weight 3)
if h1_adx < 15
    score_v := score_v > 0 ? score_v - math.abs(score_v) * 0.5 : score_v + math.abs(score_v) * 0.5
else if h1_adx > 30
    if h1_dp > h1_dm
        score_v := score_v + 3
    else
        score_v := score_v - 3
else if h1_adx > 20
    if h1_dp > h1_dm
        score_v := score_v + 1
    else
        score_v := score_v - 1
maxp_v := maxp_v + 3

// I. Williams %R on H1  (weight 1)
if h1_wr > -20
    score_v := score_v - 1
else if h1_wr < -80
    score_v := score_v + 1
maxp_v := maxp_v + 1

// K. Momentum on H1 (10-bar %)  (weight 2)
if h1_mom > 0.15
    score_v := score_v + 2
else if h1_mom < -0.15
    score_v := score_v - 2
else if h1_mom > 0.05
    score_v := score_v + 1
else if h1_mom < -0.05
    score_v := score_v - 1
maxp_v := maxp_v + 2

// M. Multi-TF agreement (D1+H4+H1+M15)  (weight 3)
bull4 = (d1_close > d1_ema50 ? 1 : 0) + (h4_close > h4_ema50 ? 1 : 0) + (h1_close > h1_ema20 ? 1 : 0) + (m15_close > m15_ema20 ? 1 : 0)
if bull4 == 4
    score_v := score_v + 3
else if bull4 == 0
    score_v := score_v - 3
else if bull4 >= 3
    score_v := score_v + 1
else if bull4 <= 1
    score_v := score_v - 1
maxp_v := maxp_v + 3

// O. M15 EMA20/50 cross  (weight 1)
if m15_ema20 > m15_ema50
    score_v := score_v + 1
else
    score_v := score_v - 1
maxp_v := maxp_v + 1

// ── CONFIDENCE ─────────────────────────────────────────────────────────
ratio = maxp_v > 0 ? math.min(1.0, math.abs(score_v) / maxp_v) : 0.0
confidence_pct = math.round(math.max(50, math.min(95, 50 + 45 * (1 - math.exp(-3.66 * ratio)))))
direction = score_v > 0 ? "BUY" : score_v < 0 ? "SELL" : "—"
isStrong  = confidence_pct >= gateConf and direction != "—"

// Track previous direction to plot ONE label per fresh signal, not per bar
var string prevDir = "—"
freshBuy  = isStrong and direction == "BUY"  and prevDir != "BUY"
freshSell = isStrong and direction == "SELL" and prevDir != "SELL"
if isStrong
    prevDir := direction

// ── PLOT SIGNALS ───────────────────────────────────────────────────────
plotshape(showSignals and freshBuy,  title="BUY",
          style=shape.labelup,   location=location.belowbar,
          color=color.new(color.green, 0), textcolor=color.white,
          text="BUY", size=size.small)

plotshape(showSignals and freshSell, title="SELL",
          style=shape.labeldown, location=location.abovebar,
          color=color.new(color.red, 0),   textcolor=color.white,
          text="SELL", size=size.small)

// ── INFO TABLE (top-right, last bar) ───────────────────────────────────
var table tbl = table.new(position.top_right, 2, 6,
                          border_color=color.new(color.gray, 50), border_width=1)

if barstate.islast and showInfoTable
    sigBg = isStrong and direction == "BUY"  ? color.new(color.green, 20) : isStrong and direction == "SELL" ? color.new(color.red, 20)   : color.new(color.gray, 30)
    bgDk  = color.new(color.black, 70)
    table.cell(tbl, 0, 0, "FOREX-28",       text_color=color.white, bgcolor=color.new(color.blue, 30), text_size=size.small)
    table.cell(tbl, 1, 0, syminfo.ticker,    text_color=color.white, bgcolor=color.new(color.blue, 30), text_size=size.small)
    table.cell(tbl, 0, 1, "Сигнал",          text_color=color.silver, bgcolor=bgDk, text_size=size.small)
    table.cell(tbl, 1, 1, isStrong ? direction : "ОЖИДАНИЕ", text_color=color.white, bgcolor=sigBg, text_size=size.small)
    table.cell(tbl, 0, 2, "Уверенность",     text_color=color.silver, bgcolor=bgDk, text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(confidence_pct) + "%",          text_color=color.white, bgcolor=sigBg, text_size=size.small)
    table.cell(tbl, 0, 3, "Score / Max",     text_color=color.silver, bgcolor=bgDk, text_size=size.small)
    table.cell(tbl, 1, 3, str.tostring(math.round(score_v)) + " / " + str.tostring(math.round(maxp_v)), text_color=color.white, bgcolor=bgDk, text_size=size.small)
    table.cell(tbl, 0, 4, "Порог входа",     text_color=color.silver, bgcolor=bgDk, text_size=size.small)
    table.cell(tbl, 1, 4, "≥ " + str.tostring(gateConf) + "%",          text_color=color.white, bgcolor=bgDk, text_size=size.small)
    table.cell(tbl, 0, 5, "Цена",            text_color=color.silver, bgcolor=bgDk, text_size=size.small)
    table.cell(tbl, 1, 5, str.tostring(close, format.mintick),         text_color=color.white, bgcolor=bgDk, text_size=size.small)

// ── ALERTS ─────────────────────────────────────────────────────────────
// Pine `alertcondition` requires a *const* message string, so we keep the
// alert text static.  The actual confidence/gate value at signal time is
// available in the chart's info table and via the {{ticker}} placeholder.
alertcondition(freshBuy,  title="FX-28 BUY",  message="BUY {{ticker}} — FOREX-28 signal (conf >= gateConf)")
alertcondition(freshSell, title="FX-28 SELL", message="SELL {{ticker}} — FOREX-28 signal (conf >= gateConf)")
