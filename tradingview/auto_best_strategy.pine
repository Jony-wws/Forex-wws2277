// Current signal: BUY (confidence 92%, ADX 45)

// --- Live Signal Logic (pair #1) ---
adx_len = input.int(14, "ADX Length")
[diPlus, diMinus, adxVal] = ta.dmi(adx_len, adx_len)
ema_fast = ta.ema(close, 8)
ema_slow = ta.ema(close, 21)

bull_signal = adxVal >= s1_adx_min and adxVal <= s1_adx_max and ema_fast > ema_slow and diPlus > diMinus
bear_signal = adxVal >= s1_adx_min and adxVal <= s1_adx_max and ema_fast < ema_slow and diMinus > diPlus

plotshape(bull_signal, style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small, title="BUY")
plotshape(bear_signal, style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, title="SELL")

