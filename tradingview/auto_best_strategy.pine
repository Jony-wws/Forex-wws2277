// Top-3 strategies from latest sweep

indicator("FOREX Auto-Strategy [2026-05-20 01:50 UTC+5]", overlay=true)

// === 1. EURUSD — WR 51.91% · 23.4 trades/day ===
s1_adx_min = input.float(12, "#1 EURUSD ADX min")
s1_adx_max = input.float(50.0, "#1 EURUSD ADX max")
s1_conf_min = input.int(70, "#1 EURUSD Min Confidence")
s1_tq_min = input.int(50, "#1 EURUSD Min Trend Quality")
s1_horizon = input.int(240, "#1 EURUSD Horizon (min)")
s1_require_mtf = input.bool(true, "#1 EURUSD Require MTF")

// Current signal: SELL (confidence 91%, ADX 34)

// === 2. AUDNZD — WR 71.11% · 5.4 trades/day ===
s2_adx_min = input.float(18, "#2 AUDNZD ADX min")
s2_adx_max = input.float(60.0, "#2 AUDNZD ADX max")
s2_conf_min = input.int(72, "#2 AUDNZD Min Confidence")
s2_tq_min = input.int(75, "#2 AUDNZD Min Trend Quality")
s2_horizon = input.int(300, "#2 AUDNZD Horizon (min)")
s2_require_mtf = input.bool(true, "#2 AUDNZD Require MTF")

// Current signal: WAIT (confidence 84%, ADX 45)

// === 3. GBPCHF — WR 60.14% · 3.5 trades/day ===
s3_adx_min = input.float(18, "#3 GBPCHF ADX min")
s3_adx_max = input.float(60.0, "#3 GBPCHF ADX max")
s3_conf_min = input.int(72, "#3 GBPCHF Min Confidence")
s3_tq_min = input.int(75, "#3 GBPCHF Min Trend Quality")
s3_horizon = input.int(420, "#3 GBPCHF Horizon (min)")
s3_require_mtf = input.bool(true, "#3 GBPCHF Require MTF")

// Current signal: WAIT (confidence 87%, ADX 40)

// --- Live Signal Logic (pair #1) ---
adx_len = input.int(14, "ADX Length")
[diPlus, diMinus, adxVal] = ta.dmi(adx_len, adx_len)
ema_fast = ta.ema(close, 8)
ema_slow = ta.ema(close, 21)

bull_signal = adxVal >= s1_adx_min and adxVal <= s1_adx_max and ema_fast > ema_slow and diPlus > diMinus
bear_signal = adxVal >= s1_adx_min and adxVal <= s1_adx_max and ema_fast < ema_slow and diMinus > diPlus

plotshape(bull_signal, style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small, title="BUY")
plotshape(bear_signal, style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, title="SELL")

// WR: 51.91% on 365-day backtest
