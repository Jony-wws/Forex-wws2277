// --- Live Signal Logic (pair #1) ---
adx_len = input.int(14, "ADX Length")
[diPlus, diMinus, adxVal] = ta.dmi(adx_len, adx_len)
ema_fast = ta.ema(close, 8)
ema_slow = ta.ema(close, 21)

bull_signal = adxVal >= s1_adx_min and adxVal <= s1_adx_max and ema_fast > ema_slow and diPlus > diMinus
