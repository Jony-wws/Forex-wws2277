// @version=5
// Auto-generated by cycle_5h at 2026-05-06 22:38 UTC+5
//
// FOREX 5h Sustained Trend (M15) — индикатор для долгих трендов
//
// Логика: BUY/SELL появляется только когда ВСЕ фильтры согласны →
// движение ожидается минимум 5 часов (20 M15 баров).
// Меньше ложных сигналов, больше тренд.
//
// Top-3 пар по бэктесту (последний цикл, 365 дней):
//   #1 AUDNZD  WR 70.53%  ·  5.7 сделок/день  ·  сейчас: SELL (92% conf, ADX 44)
//   #2 EURCHF  WR 55.52%  ·  11.2 сделок/день  ·  сейчас: BUY (62% conf, ADX 18)
//   #3 NZDCHF  WR 53.70%  ·  13.0 сделок/день  ·  сейчас: BUY (79% conf, ADX 28)
//
// Применение:
//   1) Открой TradingView, выбери ЛЮБУЮ из 28 forex пар, переключи на M15.
//   2) Indicators → Add this script → "FOREX 5h Trend".
//   3) Зелёная стрелка ▲ снизу = BUY, красная ▼ сверху = SELL.
//   4) Целевая цена (через 5h) показана пунктирной линией от стрелки.
//
// =============================================================================

indicator("FOREX 5h Trend [M15] — 2026-05-06 22:38 UTC+5", overlay=true, max_labels_count=300, max_lines_count=300)

// ============================ INPUTS ==========================================
grpFilter   = "Фильтры тренда"
adx_len     = input.int(14, "ADX длина", group=grpFilter, minval=5, maxval=50)
adx_strong  = input.float(30.0, "ADX минимум (сильный тренд)", group=grpFilter, minval=15, maxval=60)
adx_max     = input.float(60.0, "ADX максимум (без перегиба)", group=grpFilter, minval=40, maxval=80)
di_spread   = input.float(5.0,  "DI+/DI- спред минимум", group=grpFilter, minval=0, maxval=20)

grpEma      = "EMA стек (тренд по нескольким ТФ)"
ema_fast    = input.int(9,   "EMA быстрая (M15)", group=grpEma)
ema_mid     = input.int(21,  "EMA средняя (M15)", group=grpEma)
ema_slow    = input.int(55,  "EMA медленная (M15)", group=grpEma)
ema_anchor  = input.int(200, "EMA якорь (M15) — общий тренд", group=grpEma)
require_h1  = input.bool(true, "Требовать H1 EMA21 > EMA55 (для BUY)", group=grpEma)
require_h4  = input.bool(true, "Требовать H4 EMA21 > EMA55 (для BUY)", group=grpEma)

grpRsi      = "RSI / моментум"
rsi_len     = input.int(14, "RSI длина", group=grpRsi)
rsi_buy_min = input.float(45.0, "RSI BUY минимум", group=grpRsi)
rsi_buy_max = input.float(70.0, "RSI BUY максимум (не перекуплен)", group=grpRsi)
rsi_sell_min= input.float(30.0, "RSI SELL минимум (не перепродан)", group=grpRsi)
rsi_sell_max= input.float(55.0, "RSI SELL максимум", group=grpRsi)

grpAtr      = "ATR — ожидаемое движение"
atr_len     = input.int(14, "ATR длина", group=grpAtr)
horizon_h   = input.int(5,  "Горизонт (часов)", group=grpAtr, minval=1, maxval=24)
horizon_bars_input = input.int(20, "Горизонт (баров M15)", group=grpAtr, minval=4, maxval=96)

grpCool     = "Cooldown / антишум"
cooldown_bars = input.int(20, "Минимум баров между сигналами", group=grpCool, minval=4, maxval=200)
slope_lookback= input.int(10, "Бары для проверки наклона EMA55", group=grpCool, minval=3, maxval=50)

grpPlot     = "Внешний вид"
show_labels = input.bool(true, "Показывать метки BUY/SELL", group=grpPlot)
show_emas   = input.bool(true, "Рисовать EMA-стек", group=grpPlot)
show_target = input.bool(true, "Линия цели (через 5h)", group=grpPlot)
show_panel  = input.bool(true, "Панель статуса", group=grpPlot)

// ============================ CALCS ===========================================
ema9   = ta.ema(close, ema_fast)
ema21  = ta.ema(close, ema_mid)
ema55  = ta.ema(close, ema_slow)
ema200 = ta.ema(close, ema_anchor)

[diPlus, diMinus, adxVal] = ta.dmi(adx_len, adx_len)
rsi_now = ta.rsi(close, rsi_len)
atr_now = ta.atr(atr_len)

// EMA stack — strong bullish stack means trend has multi-period structure
bull_stack_m15 = ema9 > ema21 and ema21 > ema55 and ema55 > ema200
bear_stack_m15 = ema9 < ema21 and ema21 < ema55 and ema55 < ema200

// Slope of EMA55 — must be in trade direction (avoid flat markets)
ema55_slope_up   = ema55 > ema55[slope_lookback]
ema55_slope_down = ema55 < ema55[slope_lookback]

// Higher-TF confirmation (request.security w/ lookahead off — safe values)
h1_ema21 = request.security(syminfo.tickerid, "60",  ta.ema(close, ema_mid), barmerge.gaps_off, barmerge.lookahead_off)
h1_ema55 = request.security(syminfo.tickerid, "60",  ta.ema(close, ema_slow), barmerge.gaps_off, barmerge.lookahead_off)
h4_ema21 = request.security(syminfo.tickerid, "240", ta.ema(close, ema_mid), barmerge.gaps_off, barmerge.lookahead_off)
h4_ema55 = request.security(syminfo.tickerid, "240", ta.ema(close, ema_slow), barmerge.gaps_off, barmerge.lookahead_off)

h1_bull_ok = not require_h1 or h1_ema21 > h1_ema55
h1_bear_ok = not require_h1 or h1_ema21 < h1_ema55
h4_bull_ok = not require_h4 or h4_ema21 > h4_ema55
h4_bear_ok = not require_h4 or h4_ema21 < h4_ema55

// ADX & DMI gate
adx_gate    = adxVal >= adx_strong and adxVal <= adx_max
di_bull_gate = diPlus - diMinus >= di_spread
di_bear_gate = diMinus - diPlus >= di_spread

// RSI gate (not at extreme)
rsi_bull_gate = rsi_now >= rsi_buy_min and rsi_now <= rsi_buy_max
rsi_bear_gate = rsi_now >= rsi_sell_min and rsi_now <= rsi_sell_max

// Composite signal (ALL gates must be true)
buy_raw  = bull_stack_m15 and ema55_slope_up   and adx_gate and di_bull_gate and rsi_bull_gate and h1_bull_ok and h4_bull_ok and close > ema200
sell_raw = bear_stack_m15 and ema55_slope_down and adx_gate and di_bear_gate and rsi_bear_gate and h1_bear_ok and h4_bear_ok and close < ema200

// Cooldown: only emit if no signal of EITHER kind in last `cooldown_bars`
var int last_signal_bar = na
new_buy  = buy_raw  and (na(last_signal_bar) or (bar_index - last_signal_bar) >= cooldown_bars)
new_sell = sell_raw and (na(last_signal_bar) or (bar_index - last_signal_bar) >= cooldown_bars)
if new_buy or new_sell
    last_signal_bar := bar_index

// Target price = entry + (ATR * horizon_bars * 0.6) (rough 5h move estimate)
target_pp   = atr_now * horizon_bars_input * 0.6
buy_target  = close + target_pp
sell_target = close - target_pp
target_bar  = bar_index + horizon_bars_input
target_pp_str = str.tostring(target_pp / syminfo.mintick, "#.#")
buy_label_text  = "цель +" + target_pp_str + " пп"
sell_label_text = "цель -" + target_pp_str + " пп"

// ============================ PLOTTING =======================================
plot(show_emas ? ema21  : na, title="EMA21",  color=color.new(color.aqua, 30),   linewidth=1)
plot(show_emas ? ema55  : na, title="EMA55",  color=color.new(color.orange, 30), linewidth=2)
plot(show_emas ? ema200 : na, title="EMA200", color=color.new(color.gray, 30),   linewidth=2)

plotshape(show_labels and new_buy,  title="BUY",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.green, 0), size=size.normal, text="BUY",  textcolor=color.white)
plotshape(show_labels and new_sell, title="SELL", style=shape.triangledown, location=location.abovebar, color=color.new(color.red,   0), size=size.normal, text="SELL", textcolor=color.white)

draw_buy  = show_target and new_buy
draw_sell = show_target and new_sell

dummy_buy_line  = draw_buy  ? line.new(bar_index, close, target_bar, buy_target,  color=color.new(color.green, 50), style=line.style_dashed) : na
dummy_buy_lbl   = draw_buy  ? label.new(target_bar, buy_target,  buy_label_text,  color=color.new(color.green, 80), textcolor=color.white, size=size.small, style=label.style_label_left) : na
dummy_sell_line = draw_sell ? line.new(bar_index, close, target_bar, sell_target, color=color.new(color.red, 50),   style=line.style_dashed) : na
dummy_sell_lbl  = draw_sell ? label.new(target_bar, sell_target, sell_label_text, color=color.new(color.red, 80),   textcolor=color.white, size=size.small, style=label.style_label_left) : na

// Status panel (top-right)
side_now_str = new_buy ? "BUY" : new_sell ? "SELL" : buy_raw ? "BUY-pending" : sell_raw ? "SELL-pending" : "WAIT"
side_color_v = (new_buy or buy_raw) ? color.new(color.green, 0) : (new_sell or sell_raw) ? color.new(color.red, 0) : color.new(color.gray, 0)
ema_stack_str = bull_stack_m15 ? "BULL" : bear_stack_m15 ? "BEAR" : "—"
ema_stack_col = bull_stack_m15 ? color.green : bear_stack_m15 ? color.red : color.gray
mtf_str = (h1_bull_ok and h4_bull_ok) ? "BUY-OK" : (h1_bear_ok and h4_bear_ok) ? "SELL-OK" : "no"
adx_str = str.tostring(adxVal, "#.#")
di_str  = str.tostring(diPlus, "#.#") + " / " + str.tostring(diMinus, "#.#")
rsi_str = str.tostring(rsi_now, "#.#")
atr_str = target_pp_str + " пп"

if show_panel and barstate.islast
    var table panel = table.new(position.top_right, 2, 7, frame_color=color.gray, frame_width=1, border_color=color.gray, border_width=1)
    table.cell(panel, 0, 0, "5h Trend",  bgcolor=color.new(color.black, 0), text_color=color.white)
    table.cell(panel, 1, 0, side_now_str, bgcolor=side_color_v,             text_color=color.white)
    table.cell(panel, 0, 1, "ADX",        text_color=color.white)
    table.cell(panel, 1, 1, adx_str,      text_color=adx_gate ? color.green : color.red)
    table.cell(panel, 0, 2, "DI+/DI-",    text_color=color.white)
    table.cell(panel, 1, 2, di_str,       text_color=color.white)
    table.cell(panel, 0, 3, "RSI",        text_color=color.white)
    table.cell(panel, 1, 3, rsi_str,      text_color=color.white)
    table.cell(panel, 0, 4, "EMA stack",  text_color=color.white)
    table.cell(panel, 1, 4, ema_stack_str, text_color=ema_stack_col)
    table.cell(panel, 0, 5, "H1/H4",      text_color=color.white)
    table.cell(panel, 1, 5, mtf_str,      text_color=color.white)
    table.cell(panel, 0, 6, "ATR/5h",     text_color=color.white)
    table.cell(panel, 1, 6, atr_str,      text_color=color.white)

// ============================ ALERTS =========================================
alertcondition(new_buy,  title="FOREX 5h BUY",  message="BUY 5h trend on {{ticker}} M15")
alertcondition(new_sell, title="FOREX 5h SELL", message="SELL 5h trend on {{ticker}} M15")
