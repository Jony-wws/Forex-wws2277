// === 3. AUDNZD — WR 66.86% · 10.5 trades/day ===
s3_adx_min = input.float(18, "#3 AUDNZD ADX min")
s3_adx_max = input.float(60.0, "#3 AUDNZD ADX max")
s3_conf_min = input.int(72, "#3 AUDNZD Min Confidence")
