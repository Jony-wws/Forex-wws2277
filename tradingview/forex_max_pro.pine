// © Jony-wws / Forex-wws2277  ·  FOREX MAX PRO  ·  Pine v5
//
// FULL forecast-system logic from the live FastAPI dashboard, ported to a single
// Pine indicator that works on **any of the 28 currency pairs** (majors + crosses).
// Drop it on M15 of any FX pair → get ★ ПРЕМИУМ / СТРОГИЙ / ТОП-3 labels with the
// same trend_quality, multi-TF agreement, and 18-block voting that powers the
// website. Auto-detects JPY pairs and switches the pip multiplier accordingly.
//
// What's encoded here:
//   1.  Multi-timeframe trend agreement   (D1 + H4 + H1 + M15  EMA20 vs EMA50)
//   2.  18 voting blocks on H1 + M15 indicators with weighted scoring
//   3.  Confidence (50..92 %) from the score / max-score ratio
//   4.  trend_quality composite (0..100, 7 equal-weight components)
//   5.  ★ ПРЕМИУМ gate (TQ ≥ 85, conf ≥ 88, ADX ≥ 28, |Aroon| ≥ 70,
//       HA extreme + body, |momentum| ≥ 0.20, expected 5h move ≥ 60 pp)
//   6.  СТРОГИЙ gate     (TQ ≥ 75, conf ≥ 82, multi-TF aligned)
//   7.  ТОП-3 fallback   (top by trend_quality when nothing premium / strict)
//   8.  Live dashboard table (top right) with all key fields
//   9.  5h horizon line drawn at every fresh trigger (binary expiry visual)
//  10.  Alerts for ★ ПРЕМИУМ BUY/SELL, СТРОГИЙ BUY/SELL, ТОП-3 BUY/SELL
//
// Mirrors `app/analyzer.py` / `scripts/backtest_eurusd.py` / `scripts/backtest_28pairs.py`.
// All thresholds are inputs — change them in the Settings dialog without editing code.

//@version=5
indicator(title              = "FOREX MAX PRO — 28-pair signal system",
          shorttitle         = "FX-MAX-PRO",
          overlay            = true,
          max_labels_count   = 500,
          max_lines_count    = 100,
          max_boxes_count    = 50)

// ──────────────────────────────────────────────────────────────────────
//  INPUTS
// ──────────────────────────────────────────────────────────────────────
g_disp = "1. Display"
showStrict     = input.bool(true,   "Show СТРОГИЙ (green) labels", group=g_disp)
showPremium    = input.bool(true,   "Show ★ ПРЕМИУМ (gold) labels", group=g_disp)
showTop3       = input.bool(true,   "Show ТОП-3 fallback (blue) labels", group=g_disp)
showHorizonLn  = input.bool(true,   "Draw 5h horizon line at every trigger", group=g_disp)
showInfoTable  = input.bool(true,   "Show stats table (top right)", group=g_disp)
showZones      = input.bool(true,   "Tint background by tier", group=g_disp)

g_strict = "2. Strict gate (СТРОГИЙ)"
minConfidence  = input.int(82,  "Min confidence",        minval=50, maxval=92, group=g_strict)
minTrendQ      = input.int(75,  "Min trend_quality",     minval=0,  maxval=100, group=g_strict)
requireMTF     = input.bool(true, "Require multi-TF aligned", group=g_strict)

g_prem = "3. Premium gate (★ ПРЕМИУМ)"
premMinConf    = input.int(88,    "Min confidence",     minval=50, maxval=95, group=g_prem)
premMinTrendQ  = input.int(85,    "Min trend_quality",  minval=0,  maxval=100, group=g_prem)
premMinAdx     = input.float(28.0, "Min ADX(1h)",       minval=10, maxval=60, step=1.0, group=g_prem)
premMinAroon   = input.float(70.0, "Min |Aroon osc|",   minval=0,  maxval=100, step=5.0, group=g_prem)
premMinHA      = input.float(0.83, "Min HA bull-extreme", minval=0.5, maxval=1.0, step=0.01, group=g_prem)
premMinHABody  = input.float(0.55, "Min HA body strength", minval=0.0, maxval=1.0, step=0.05, group=g_prem)
premMinMom     = input.float(0.20, "Min |Momentum %|",  minval=0.0, maxval=1.0, step=0.05, group=g_prem)
premMinMovePp  = input.float(60.0, "Min expected 5h move (pips, non-JPY)", minval=10, maxval=300, step=5.0, group=g_prem)
premMinMovePpJ = input.float(100.0,"Min expected 5h move (pips, JPY)",     minval=10, maxval=300, step=5.0, group=g_prem)

g_fc = "4. Forecast"
expiryHours    = input.float(5.0, "Forecast horizon (hours)", minval=1, maxval=24, step=0.5, group=g_fc)

g_top3 = "5. Top-3 fallback"
top3MinConf    = input.int(70, "Top-3: min confidence",       minval=50, maxval=92, group=g_top3)
top3MinTrendQ  = input.int(60, "Top-3: min trend_quality",    minval=0,  maxval=100, group=g_top3)

// ──────────────────────────────────────────────────────────────────────
//  PAIR DETECTION  →  pip multiplier (auto)
// ──────────────────────────────────────────────────────────────────────
isJpy        = str.contains(syminfo.ticker, "JPY")
pipMult      = isJpy ? 100.0 : 10000.0
premMinMove  = isJpy ? premMinMovePpJ : premMinMovePp

// ──────────────────────────────────────────────────────────────────────
//  HELPERS
// ──────────────────────────────────────────────────────────────────────
f_aroon(period) =>
    upPos   = ta.highestbars(high, period + 1)
    downPos = ta.lowestbars (low,  period + 1)
    upVal   = 100.0 * (period + upPos)   / period
    dnVal   = 100.0 * (period + downPos) / period
    [upVal, dnVal, upVal - dnVal]

f_cci(period) =>
    typ  = (high + low + close) / 3.0
    sma  = ta.sma(typ, period)
    mad  = ta.dev(typ, period)
    safe = mad == 0 ? 1.0 : 0.015 * mad
    (typ - sma) / safe

f_scale(v, lo, hi) =>
    hi <= lo ? 0.0 : math.max(0.0, math.min(100.0, (v - lo) * 100.0 / (hi - lo)))

// Heiken Ashi smoothed candles + bull-ratio + body-strength over last 6 bars.
var float ha_open_prev = na
ha_close_v = (open + high + low + close) / 4.0
ha_open_v  = na(ha_open_prev) ? (open + close) / 2.0 : (ha_open_prev + ha_close_v[1]) / 2.0
ha_open_prev := ha_open_v
ha_high_v   = math.max(high, math.max(ha_open_v, ha_close_v))
ha_low_v    = math.min(low,  math.min(ha_open_v, ha_close_v))
ha_bull_bar = ha_close_v > ha_open_v ? 1 : 0
ha_body_pct = ha_high_v == ha_low_v ? 0.0 : math.abs(ha_close_v - ha_open_v) / (ha_high_v - ha_low_v)
ha_bull_ratio_6  = ta.sma(ha_bull_bar, 6)
ha_body_strength = ta.sma(ha_body_pct, 6)

// ──────────────────────────────────────────────────────────────────────
//  MULTI-TIMEFRAME TREND  (D1 + H4 + H1 + M15)
// ──────────────────────────────────────────────────────────────────────
f_tf_dir() =>
    e20 = ta.ema(close, 20)
    e50 = ta.ema(close, 50)
    close > e20 and e20 > e50 ? 1 : (close < e20 and e20 < e50 ? -1 : 0)

dir_d1  = request.security(syminfo.tickerid, "D",   f_tf_dir(), barmerge.gaps_off, barmerge.lookahead_off)
dir_h4  = request.security(syminfo.tickerid, "240", f_tf_dir(), barmerge.gaps_off, barmerge.lookahead_off)
dir_h1  = request.security(syminfo.tickerid, "60",  f_tf_dir(), barmerge.gaps_off, barmerge.lookahead_off)
dir_m15 = f_tf_dir()

bull_count = (dir_d1==1?1:0) + (dir_h4==1?1:0) + (dir_h1==1?1:0) + (dir_m15==1?1:0)
bear_count = (dir_d1==-1?1:0) + (dir_h4==-1?1:0) + (dir_h1==-1?1:0) + (dir_m15==-1?1:0)
multi_tf_aligned = bull_count >= 3 or bear_count >= 3
mtf_dir          = bull_count >= 3 ? 1 : (bear_count >= 3 ? -1 : 0)

// ──────────────────────────────────────────────────────────────────────
//  H1 INDICATORS (decision timeframe)
// ──────────────────────────────────────────────────────────────────────
f_h1_block() =>
    e20 = ta.ema(close, 20)
    e50 = ta.ema(close, 50)
    rsi14 = ta.rsi(close, 14)
    [_macd, _signal, hist]   = ta.macd(close, 12, 26, 9)
    k                        = ta.stoch(close, high, low, 14)
    d_                       = ta.sma(k, 3)
    [bb_m, bb_t_dummy, bb_b] = ta.bb(close, 20, 2.0)
    bb_pct                   = (close - bb_b) / (bb_t_dummy - bb_b)
    [dp, dm, ax]             = ta.dmi(14, 14)
    williams                 = ta.wpr(14)
    momentum                 = (close - close[12]) / close[12] * 100.0
    [_aru, _ard, osc_a]      = f_aroon(25)
    cci_v                    = f_cci(20)
    atr_v                    = ta.atr(14)
    atr_avg                  = ta.sma(atr_v, 50)
    [e20, e50, rsi14, hist, k, d_, bb_pct, dp, dm, ax, williams, momentum, osc_a, cci_v, atr_v, atr_avg]

[h1_e20, h1_e50, h1_rsi, h1_macd_h, h1_k, h1_d, h1_bb, h1_dp, h1_dm, h1_adx, h1_wpr, h1_mom, h1_aro, h1_cci, h1_atr, h1_atr_avg] = request.security(syminfo.tickerid, "60", f_h1_block(), barmerge.gaps_off, barmerge.lookahead_off)

// M15 secondary block — used for entry-quality and CCI/Stoch refinement.
m15_rsi  = ta.rsi(close, 14)
m15_k    = ta.stoch(close, high, low, 14)
m15_d    = ta.sma(m15_k, 3)
m15_atr  = ta.atr(14)
m15_atr_avg = ta.sma(m15_atr, 50)
m15_mom  = (close - close[12]) / close[12] * 100.0
[_m_aru, _m_ard, m15_aro] = f_aroon(25)
m15_cci  = f_cci(20)
m15_wpr  = ta.wpr(14)
m15_e20  = ta.ema(close, 20)
m15_e50  = ta.ema(close, 50)
[_, _, m15_macd_h] = ta.macd(close, 12, 26, 9)

// ──────────────────────────────────────────────────────────────────────
//  VOTING BLOCKS  (mirror app/analyzer.py — 18 blocks A..R, weights matched)
// ──────────────────────────────────────────────────────────────────────
score = 0.0
maxScore = 0.0
addVote(condBuy, condSell, weight) =>
    s = condBuy ? weight : (condSell ? -weight : 0.0)
    [s, weight]

// Block A — H1 EMA20 vs EMA50            ±3.0
[sA, wA] = addVote(h1_e20 > h1_e50, h1_e20 < h1_e50, 3.0)
score += sA, maxScore += wA

// Block B — H1 RSI(14) momentum          ±2.0
[sB, wB] = addVote(h1_rsi > 55, h1_rsi < 45, 2.0)
score += sB, maxScore += wB

// Block C — H1 MACD histogram            ±2.5
[sC, wC] = addVote(h1_macd_h > 0, h1_macd_h < 0, 2.5)
score += sC, maxScore += wC

// Block D — H1 Stochastic                ±1.5
[sD, wD] = addVote(h1_k > h1_d and h1_k < 80, h1_k < h1_d and h1_k > 20, 1.5)
score += sD, maxScore += wD

// Block E — H1 Bollinger %B              ±1.5
[sE, wE] = addVote(h1_bb > 0.6, h1_bb < 0.4, 1.5)
score += sE, maxScore += wE

// Block F — H1 ADX + DI cross            ±3.0
[sF, wF] = addVote(h1_adx > 20 and h1_dp > h1_dm, h1_adx > 20 and h1_dm > h1_dp, 3.0)
score += sF, maxScore += wF

// Block G — H1 Williams %R               ±1.5
[sG, wG] = addVote(h1_wpr > -20, h1_wpr < -80, 1.5)
score += sG, maxScore += wG

// Block H — H1 Momentum                  ±2.0
[sH, wH] = addVote(h1_mom > 0.05, h1_mom < -0.05, 2.0)
score += sH, maxScore += wH

// Block I — Multi-TF alignment           ±4.0
[sI, wI] = addVote(mtf_dir == 1, mtf_dir == -1, 4.0)
score += sI, maxScore += wI

// Block J — M15 EMA cross                ±1.0
[sJ, wJ] = addVote(m15_e20 > m15_e50, m15_e20 < m15_e50, 1.0)
score += sJ, maxScore += wJ

// Block K — M15 RSI                      ±1.0
[sK, wK] = addVote(m15_rsi > 55, m15_rsi < 45, 1.0)
score += sK, maxScore += wK

// Block L — M15 MACD histogram           ±1.0
[sL, wL] = addVote(m15_macd_h > 0, m15_macd_h < 0, 1.0)
score += sL, maxScore += wL

// Block M — M15 Williams %R              ±1.0
[sM, wM] = addVote(m15_wpr > -20, m15_wpr < -80, 1.0)
score += sM, maxScore += wM

// Block N — M15 ATR / avg-ATR (vol regime) ±1.0
volOk = m15_atr_avg > 0 and m15_atr / m15_atr_avg > 1.0
[sN, wN] = addVote(volOk and score > 0, volOk and score < 0, 1.0)
score += sN, maxScore += wN

// Block P — H1 Aroon oscillator          ±2.0
[sP, wP] = addVote(h1_aro >  50, h1_aro < -50, 2.0)
score += sP, maxScore += wP

// Block Q — H1 CCI                       ±2.0
[sQ, wQ] = addVote(h1_cci > 100, h1_cci < -100, 2.0)
score += sQ, maxScore += wQ

// Block R — Heiken Ashi (M15 directional persistence + body) ±2.0
[sR, wR] = addVote(ha_bull_ratio_6 >= 0.83 and ha_body_strength >= 0.5,
                   ha_bull_ratio_6 <= 0.17 and ha_body_strength >= 0.5, 2.0)
score += sR, maxScore += wR

// Block S — M15 Aroon                    ±1.0
[sS, wS] = addVote(m15_aro >  50, m15_aro < -50, 1.0)
score += sS, maxScore += wS

absScore    = math.abs(score)
score_ratio = maxScore > 0.0 ? absScore / maxScore : 0.0

// Confidence: 50 + 45·(1 − exp(−3.66·score_ratio)), clamped to [50, 92].
confidence = math.min(92.0, math.max(50.0, 50.0 + 45.0 * (1.0 - math.exp(-3.66 * score_ratio))))

// ──────────────────────────────────────────────────────────────────────
//  TREND QUALITY  (0..100, 7 equal-weight components)
// ──────────────────────────────────────────────────────────────────────
q_score   = f_scale(score_ratio, 0.0, 0.40)
q_adx     = f_scale(h1_adx, 15.0, 30.0)
q_aroon   = f_scale(math.abs(h1_aro), 30.0, 70.0)
q_ha_dir  = math.abs(ha_bull_ratio_6 - 0.5) * 2.0
q_ha      = math.max(0.0, math.min(100.0, q_ha_dir * 100.0 * (0.5 + 0.5 * ha_body_strength)))
q_mtf     = bull_count == 4 or bull_count == 0 ? 100.0 : (bull_count == 3 or bull_count == 1 ? 50.0 : 0.0)
q_atr     = h1_atr_avg > 0 ? f_scale(h1_atr / h1_atr_avg, 0.7, 1.5) : 0.0
q_mom     = f_scale(math.abs(h1_mom), 0.05, 0.30)
trend_quality = (q_score + q_adx + q_aroon + q_ha + q_mtf + q_atr + q_mom) / 7.0

// Expected 5h move in pips (auto JPY-aware).
expected_move_pips_5h = h1_atr * 5.0 * pipMult

// ──────────────────────────────────────────────────────────────────────
//  TIER CLASSIFICATION  (★ ПРЕМИУМ / СТРОГИЙ / ТОП-3 / no signal)
// ──────────────────────────────────────────────────────────────────────
side_buy  = score > 0
side_sell = score < 0

is_strict_buy  = side_buy  and confidence >= minConfidence and trend_quality >= minTrendQ and (not requireMTF or (multi_tf_aligned and mtf_dir ==  1))
is_strict_sell = side_sell and confidence >= minConfidence and trend_quality >= minTrendQ and (not requireMTF or (multi_tf_aligned and mtf_dir == -1))

is_prem_common = trend_quality >= premMinTrendQ and confidence >= premMinConf and h1_adx >= premMinAdx and math.abs(h1_aro) >= premMinAroon and ha_body_strength >= premMinHABody and math.abs(h1_mom) >= premMinMom and expected_move_pips_5h >= premMinMove and (not requireMTF or multi_tf_aligned)

is_prem_buy  = is_strict_buy  and is_prem_common and ha_bull_ratio_6 >= premMinHA          and mtf_dir ==  1
is_prem_sell = is_strict_sell and is_prem_common and ha_bull_ratio_6 <= 1.0 - premMinHA    and mtf_dir == -1

// Top-3 fallback — fires when nothing premium / strict but trend_quality is decent.
is_top3_buy  = side_buy  and confidence >= top3MinConf and trend_quality >= top3MinTrendQ and not is_strict_buy  and not is_prem_buy
is_top3_sell = side_sell and confidence >= top3MinConf and trend_quality >= top3MinTrendQ and not is_strict_sell and not is_prem_sell

// Fresh-trigger logic: only fire on the bar that newly entered each gate.
new_strict_buy  = is_strict_buy  and not is_strict_buy[1]
new_strict_sell = is_strict_sell and not is_strict_sell[1]
new_prem_buy    = is_prem_buy    and not is_prem_buy[1]
new_prem_sell   = is_prem_sell   and not is_prem_sell[1]
new_top3_buy    = is_top3_buy    and not is_top3_buy[1]
new_top3_sell   = is_top3_sell   and not is_top3_sell[1]

// ──────────────────────────────────────────────────────────────────────
//  PLOT LABELS
// ──────────────────────────────────────────────────────────────────────
prem_buy_color  = color.new(color.yellow, 0)
prem_sell_color = color.new(color.orange, 0)
strict_buy_col  = color.new(color.green, 0)
strict_sell_col = color.new(color.red,   0)
top3_buy_col    = color.new(color.aqua,  0)
top3_sell_col   = color.new(color.fuchsia, 0)

if showPremium and barstate.isconfirmed and new_prem_buy
    label.new(bar_index, low,
              "★ ПРЕМИУМ\nBUY  " + str.tostring(confidence, "#") + "% | TQ " + str.tostring(trend_quality, "#") +
              "\n→ " + str.tostring(expected_move_pips_5h, "#") + " pp / " + str.tostring(expiryHours, "#") + "h",
              style=label.style_label_up, color=prem_buy_color, textcolor=color.black, size=size.normal)

if showPremium and barstate.isconfirmed and new_prem_sell
    label.new(bar_index, high,
              "★ ПРЕМИУМ\nSELL " + str.tostring(confidence, "#") + "% | TQ " + str.tostring(trend_quality, "#") +
              "\n→ " + str.tostring(expected_move_pips_5h, "#") + " pp / " + str.tostring(expiryHours, "#") + "h",
              style=label.style_label_down, color=prem_sell_color, textcolor=color.black, size=size.normal)

if showStrict and barstate.isconfirmed and new_strict_buy and not new_prem_buy
    label.new(bar_index, low,
              "СТРОГИЙ\nBUY " + str.tostring(confidence, "#") + "% / TQ " + str.tostring(trend_quality, "#"),
              style=label.style_label_up, color=strict_buy_col, textcolor=color.white, size=size.small)

if showStrict and barstate.isconfirmed and new_strict_sell and not new_prem_sell
    label.new(bar_index, high,
              "СТРОГИЙ\nSELL " + str.tostring(confidence, "#") + "% / TQ " + str.tostring(trend_quality, "#"),
              style=label.style_label_down, color=strict_sell_col, textcolor=color.white, size=size.small)

if showTop3 and barstate.isconfirmed and new_top3_buy
    label.new(bar_index, low,
              "ТОП-3\nBUY " + str.tostring(confidence, "#") + "% / TQ " + str.tostring(trend_quality, "#"),
              style=label.style_label_up, color=top3_buy_col, textcolor=color.black, size=size.tiny)

if showTop3 and barstate.isconfirmed and new_top3_sell
    label.new(bar_index, high,
              "ТОП-3\nSELL " + str.tostring(confidence, "#") + "% / TQ " + str.tostring(trend_quality, "#"),
              style=label.style_label_down, color=top3_sell_col, textcolor=color.black, size=size.tiny)

// 5h horizon line at every fresh trigger.
expiryBars = math.round(expiryHours * 60.0 * 60.0 / timeframe.in_seconds())
if showHorizonLn and barstate.isconfirmed and (new_prem_buy or new_prem_sell or new_strict_buy or new_strict_sell or new_top3_buy or new_top3_sell)
    is_buy = new_prem_buy or new_strict_buy or new_top3_buy
    line.new(x1=bar_index, y1=close, x2=bar_index + expiryBars, y2=close,
             color=color.new(is_buy ? color.green : color.red, 30),
             style=line.style_dashed, width=2)

// Subtle background tint by tier.
bg_col = is_prem_buy   ? color.new(color.yellow, 88) :
         is_prem_sell  ? color.new(color.orange, 88) :
         is_strict_buy ? color.new(color.green,  92) :
         is_strict_sell? color.new(color.red,    92) :
         is_top3_buy   ? color.new(color.aqua,   95) :
         is_top3_sell  ? color.new(color.fuchsia,95) : na
bgcolor(showZones ? bg_col : na, title="Tier tint")

// ──────────────────────────────────────────────────────────────────────
//  STATS TABLE  (top right)
// ──────────────────────────────────────────────────────────────────────
var table tbl = table.new(position.top_right, 2, 11, frame_color=color.gray, frame_width=1)
if showInfoTable and barstate.islast
    side_text = is_prem_buy or is_prem_sell  ? "★ ПРЕМИУМ " :
                is_strict_buy or is_strict_sell ? "СТРОГИЙ "  :
                is_top3_buy or is_top3_sell  ? "ТОП-3 "      : "—"
    side_text := side_text + (side_buy ? "BUY" : side_sell ? "SELL" : "")
    side_col  = is_prem_buy or is_prem_sell  ? color.yellow  :
                is_strict_buy ? color.green :
                is_strict_sell ? color.red  :
                is_top3_buy or is_top3_sell ? color.aqua : color.gray

    table.cell(tbl, 0,  0, syminfo.ticker + "  M15", bgcolor=color.new(color.blue, 0), text_color=color.white, text_size=size.small)
    table.cell(tbl, 1,  0, side_text,                bgcolor=color.new(side_col, 0),    text_color=color.white, text_size=size.small)
    table.cell(tbl, 0,  1, "Confidence",     text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1,  1, str.tostring(confidence, "#") + " %", text_color=color.white, text_size=size.small)
    table.cell(tbl, 0,  2, "Trend quality",  text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1,  2, str.tostring(trend_quality, "#") + " / 100", text_color=color.white, text_size=size.small)
    table.cell(tbl, 0,  3, "Multi-TF",       text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1,  3, str.tostring(bull_count) + " bull / " + str.tostring(bear_count) + " bear", text_color=color.white, text_size=size.small)
    table.cell(tbl, 0,  4, "Score / Max",    text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1,  4, str.tostring(score, "#.0") + " / " + str.tostring(maxScore, "#.0"), text_color=color.white, text_size=size.small)
    table.cell(tbl, 0,  5, "Expected " + str.tostring(expiryHours, "#") + "h move", text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1,  5, str.tostring(expected_move_pips_5h, "#") + " pp", text_color=color.white, text_size=size.small)
    table.cell(tbl, 0,  6, "ADX(1h)",        text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1,  6, str.tostring(h1_adx, "#"),  text_color=color.white, text_size=size.small)
    table.cell(tbl, 0,  7, "Aroon osc(1h)",  text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1,  7, str.tostring(h1_aro, "#"),  text_color=color.white, text_size=size.small)
    table.cell(tbl, 0,  8, "Momentum(1h)",   text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1,  8, str.tostring(h1_mom, "#.##") + " %", text_color=color.white, text_size=size.small)
    table.cell(tbl, 0,  9, "HA bull% / body",text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1,  9, str.tostring(ha_bull_ratio_6 * 100.0, "#") + " % / " + str.tostring(ha_body_strength, "#.##"), text_color=color.white, text_size=size.small)
    table.cell(tbl, 0, 10, "Pip mult",       text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 10, isJpy ? "JPY × 100" : "× 10000", text_color=color.white, text_size=size.small)

// ──────────────────────────────────────────────────────────────────────
//  ALERTS  (subscribe in TradingView for push notifications)
// ──────────────────────────────────────────────────────────────────────
alertcondition(new_prem_buy,    title="★ ПРЕМИУМ BUY",  message="{{ticker}} ★ ПРЕМИУМ BUY  (TQ {{plot_0}})")
alertcondition(new_prem_sell,   title="★ ПРЕМИУМ SELL", message="{{ticker}} ★ ПРЕМИУМ SELL (TQ {{plot_0}})")
alertcondition(new_strict_buy,  title="СТРОГИЙ BUY",    message="{{ticker}} СТРОГИЙ BUY  (TQ {{plot_0}})")
alertcondition(new_strict_sell, title="СТРОГИЙ SELL",   message="{{ticker}} СТРОГИЙ SELL (TQ {{plot_0}})")
alertcondition(new_top3_buy,    title="ТОП-3 BUY",      message="{{ticker}} ТОП-3 BUY")
alertcondition(new_top3_sell,   title="ТОП-3 SELL",     message="{{ticker}} ТОП-3 SELL")

// Scalar plots (so trend_quality + confidence can be referenced in alert templates).
plot(trend_quality, "trend_quality", color=color.silver, display=display.none)
plot(confidence,    "confidence",    color=color.silver, display=display.none)
plot(score,         "score",         color=color.silver, display=display.none)
plot(maxScore,      "max_score",     color=color.silver, display=display.none)
