# Data branch JSON snapshots — produced by GitHub Actions cron jobs,
# never live on main.  Keeping them out of main avoids the static
# Pages deploy ballooning and accidental clobbers between cron ticks.
data/



# Frontend (React SPA in /web)
web/node_modules/
web/dist/
web/.vite/
web/*.tsbuildinfo

# Built SPA output (emitted by `vite build` into static/dashboard/).
# Served by FastAPI at /v2 — built in CI, not checked in.
static/dashboard/

