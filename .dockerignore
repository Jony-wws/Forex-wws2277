# Keep the production image lean — only `app/`, `static/` and
# `pyproject.toml` need to ship to Fly.io.

# Runtime state regenerated by the cycle workflow.
state/
reports/

# Source control & tooling.
.git/
.github/
.gitignore
.gitattributes

# Local virtualenvs.
.venv/
venv/
env/

# Python bytecode & caches.
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Editor / OS noise.
.idea/
.vscode/
.DS_Store
Thumbs.db

# Agent metadata, scripts and tests are not needed at runtime — the
# server only imports `app/` and serves `static/`.
.agents/
scripts/
tests/
tradingview/

# Frontend artefacts: Vite build output is produced inside the image by
# the `frontend` Docker stage, not copied from the host.  Keep the
# `web/` sources (needed by the builder stage) but exclude node_modules
# and any local dev build output so we never accidentally ship stale
# bundles from a developer's laptop.
web/node_modules/
web/dist/
web/.vite/
web/*.tsbuildinfo
static/dashboard/

# Misc.
*.log
*.swp
.env
